{
  "ls": { "description": "List directory contents", "usage": "ls [path]", "category": "filesystem", "handler": "builtin:ls" },
  "cd": { "description": "Change directory", "usage": "cd <path>", "category": "filesystem", "handler": "builtin:cd", "args": {"required": 1} },
  "pwd": { "description": "Print working directory", "usage": "pwd", "category": "filesystem", "handler": "builtin:pwd" },
  "cat": { "description": "Display file contents", "usage": "cat <file>", "category": "filesystem", "handler": "builtin:cat", "args": {"required": 1} },
  "touch": { "description": "Create empty file", "usage": "touch <filename>", "category": "filesystem", "handler": "builtin:touch", "args": {"required": 1} },
  "edit": { "description": "Open file in editor", "usage": "edit <filename>", "category": "filesystem", "handler": "builtin:edit", "args": {"required": 1}, "ui": "modal" },
  "rm": { "description": "Remove file", "usage": "rm <filename>", "category": "filesystem", "handler": "builtin:rm", "args": {"required": 1} },
  "clear": { "description": "Clear terminal screen", "usage": "clear", "category": "system", "handler": "builtin:clear" },
  "lsstore": { "description": "List localStorage keys", "usage": "lsstore", "category": "storage", "handler": "builtin:lsstore" },
  "getstore": { "description": "Get value from localStorage", "usage": "getstore <key>", "category": "storage", "handler": "builtin:getstore", "args": {"required": 1} },
  "setstore": { "description": "Set value in localStorage", "usage": "setstore <key> <value>", "category": "storage", "handler": "builtin:setstore", "args": {"required": 2} },
  "delstore": { "description": "Delete key from localStorage", "usage": "delstore <key>", "category": "storage", "handler": "builtin:delstore", "args": {"required": 1}, "protected": ["wt_fs", "wt_user", "wt_host"] },
  "clearstore": { "description": "Clear non-system localStorage", "usage": "clearstore", "category": "storage", "handler": "builtin:clearstore" },
  "date": { "description": "Show current date and time", "usage": "date", "category": "system", "handler": "builtin:date" },
  "calc": { "description": "Evaluate math expression", "usage": "calc <expression>", "category": "system", "handler": "builtin:calc" },
  "neofetch": { "description": "Display system information", "usage": "neofetch", "category": "system", "handler": "builtin:neofetch" },
  "whoami": { "description": "Show current user", "usage": "whoami", "category": "system", "handler": "builtin:whoami" },
  "uname": { "description": "Print system information", "usage": "uname [options]", "category": "system", "handler": "builtin:uname" },
  "lsb_release": { "description": "Print distribution info", "usage": "lsb_release -a", "category": "system", "handler": "builtin:lsb_release" },
  "apt": { "description": "Package manager simulation", "usage": "apt [update|install <pkg>|upgrade]", "category": "system", "handler": "builtin:apt" },
  "sudo": { "description": "Execute as superuser", "usage": "sudo <command>", "category": "system", "handler": "builtin:sudo" },
  "man": { "description": "Open manual pages", "usage": "man <command>", "category": "system", "handler": "builtin:man" },
  "echo": { "description": "Print arguments", "usage": "echo <text>", "category": "system", "handler": "builtin:echo" },
  "logout": { "description": "Reset profile and reload", "usage": "logout", "category": "system", "handler": "builtin:logout", "confirm": true }
}